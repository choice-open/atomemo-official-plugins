{
  "name": "google-calendar",
  "type": "module",
  "version": "0.1.4",
  "description": "google calendar api client",
  "author": "yong yu <leoyyong@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/choice-open/atomemo-official-plugins/plugins/google-calendar#readme",
  "repository": "https://github.com/choice-open/atomemo-official-plugins/plugins/google-calendar",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "biome check . --write",
    "dev": "concurrently -c=cyan.bold,blue.bold --names=DEV,I18N --pad-prefix \"tsdown --watch\" \"typesafe-i18n\"",
    "test": "vitest run",
    "test:unit": "vitest run test/index.test.ts test/unit",
    "test:e2e": "GOOGLE_CALENDAR_E2E=1 vitest run test/e2e --no-file-parallelism",
    "release": "bumpp package.json definition.json --commit 'release google-calendar v%s' --no-push --no-tag --yes",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@choiceopen/atomemo-plugin-sdk-js": "latest",
    "dotenv": "^17.3.1",
    "googleapis": "^168.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "^1.3.10",
    "bumpp": "^10.4.1",
    "concurrently": "9.2.1",
    "tsdown": "^0.20.3",
    "typesafe-i18n": "^5.27.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  }
}
