{
  "name": "google-calendar",
  "display_name": {
    "en_US": "Google Calendar",
    "zh_Hans": "Google 日历"
  },
  "description": {
    "en_US": "Integrate Google Calendar into Atomemo workflows",
    "zh_Hans": "将 Google 日历集成到 Atomemo 工作流中"
  },
  "icon": "📅",
  "lang": "typescript",
  "repo": "https://github.com/choice-open/atomemo-official-plugins/plugins/google-calendar",
  "locales": [
    "en-US",
    "zh-Hans"
  ],
  "author": "yong yu",
  "email": "leoyyong@gmail.com",
  "version": "0.1.0",
  "credentials": [
    {
      "name": "google-calendar-oauth2",
      "display_name": {
        "en_US": "Google Calendar OAuth2",
        "zh_Hans": "Google 日历 OAuth2"
      },
      "description": {
        "en_US": "OAuth2 for Google Calendar API. Enter Client ID and Client Secret from Google Cloud Console, then authorize via the OAuth flow to connect your calendar.",
        "zh_Hans": "Google Calendar API 的 OAuth2 凭证。在 Google Cloud Console 填入 Client ID 和 Client Secret，然后通过 OAuth 授权流程连接你的日历。"
      },
      "icon": "📅",
      "oauth2": true,
      "parameters": [
        {
          "name": "client_id",
          "display_name": {
            "en_US": "Client ID",
            "zh_Hans": "客户端 ID"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "OAuth 2.0 Client ID from Google Cloud Console",
              "zh_Hans": "来自 Google Cloud Console 的 OAuth 2.0 客户端 ID"
            },
            "placeholder": {
              "en_US": "xxx.apps.googleusercontent.com",
              "zh_Hans": "xxx.apps.googleusercontent.com"
            },
            "component": "input"
          },
          "type": "string"
        },
        {
          "name": "client_secret",
          "display_name": {
            "en_US": "Client Secret",
            "zh_Hans": "客户端密钥"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "OAuth 2.0 Client Secret from Google Cloud Console",
              "zh_Hans": "来自 Google Cloud Console 的 OAuth 2.0 客户端密钥"
            },
            "component": "encrypted-input"
          },
          "type": "encrypted_string"
        },
        {
          "name": "access_token",
          "type": "encrypted_string"
        },
        {
          "name": "refresh_token",
          "type": "encrypted_string"
        },
        {
          "name": "expires_at",
          "type": "integer"
        }
      ]
    }
  ],
  "models": [],
  "tools": [
    {
      "name": "list-calendars",
      "display_name": {
        "en_US": "List Calendars",
        "zh_Hans": "列出日历"
      },
      "description": {
        "en_US": "List calendars in the user's calendar list",
        "zh_Hans": "列出用户日历列表中的日历"
      },
      "icon": "📆",
      "parameters": [
        {
          "name": "credential_id",
          "display_name": {
            "en_US": "Google Calendar Credential",
            "zh_Hans": "Google 日历凭证"
          },
          "required": true,
          "ui": {
            "component": "credential-select"
          },
          "type": "credential_id",
          "credential_name": "google-calendar-oauth2"
        }
      ]
    },
    {
      "name": "list-events",
      "display_name": {
        "en_US": "List Events",
        "zh_Hans": "列出事件"
      },
      "description": {
        "en_US": "List events from a Google Calendar",
        "zh_Hans": "从 Google 日历列出事件"
      },
      "icon": "📋",
      "parameters": [
        {
          "name": "credential_id",
          "display_name": {
            "en_US": "Google Calendar Credential",
            "zh_Hans": "Google 日历凭证"
          },
          "required": true,
          "ui": {
            "component": "credential-select"
          },
          "type": "credential_id",
          "credential_name": "google-calendar-oauth2"
        },
        {
          "name": "calendar_id",
          "display_name": {
            "en_US": "Calendar ID",
            "zh_Hans": "日历 ID"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "Primary calendar: \"primary\". Or use calendar email address.",
              "zh_Hans": "主日历使用 \"primary\"，或使用日历的邮箱地址"
            },
            "placeholder": {
              "en_US": "primary",
              "zh_Hans": "primary"
            },
            "support_expression": true,
            "width": "full",
            "component": "input"
          },
          "type": "string",
          "default": "primary"
        },
        {
          "name": "time_min",
          "display_name": {
            "en_US": "Time Min",
            "zh_Hans": "最早时间"
          },
          "required": false,
          "ui": {
            "hint": {
              "en_US": "Lower bound for event start time (ISO 8601)",
              "zh_Hans": "事件开始时间的下限（ISO 8601）"
            },
            "support_expression": true,
            "component": "input"
          },
          "type": "string"
        },
        {
          "name": "time_max",
          "display_name": {
            "en_US": "Time Max",
            "zh_Hans": "最晚时间"
          },
          "required": false,
          "ui": {
            "hint": {
              "en_US": "Upper bound for event end time (ISO 8601)",
              "zh_Hans": "事件结束时间的上限（ISO 8601）"
            },
            "support_expression": true,
            "component": "input"
          },
          "type": "string"
        },
        {
          "name": "max_results",
          "display_name": {
            "en_US": "Max Results",
            "zh_Hans": "最大返回数"
          },
          "required": false,
          "ui": {
            "hint": {
              "en_US": "Maximum number of events to return (1-2500)",
              "zh_Hans": "返回事件的最大数量（1-2500）"
            },
            "component": "number-input"
          },
          "type": "integer",
          "default": 100,
          "maximum": 2500,
          "minimum": 1
        }
      ]
    },
