{
  "name": "dingtalk",
  "display_name": {
    "en_US": "DingTalk",
    "zh_Hans": "钉钉"
  },
  "description": {
    "en_US": "Work with DingTalk users, approvals, documents, and robots.",
    "zh_Hans": "操作钉钉用户、审批、文档和机器人。"
  },
  "icon": "symbol:icon-dingtalk",
  "lang": "typescript",
  "repo": "https://github.com/choice-open/atomemo-official-plugins/plugins/dingtalk",
  "locales": [
    "en-US",
    "zh-Hans"
  ],
  "author": "Xavier",
  "email": "zhiqiang.jiang@choiceform.com",
  "version": "0.1.0",
  "credentials": [
    {
      "name": "dingtalk-app",
      "display_name": {
        "en_US": "DingTalk App Credential",
        "zh_Hans": "钉钉应用凭证"
      },
      "description": {
        "en_US": "Enterprise internal app credential for DingTalk Open Platform APIs.",
        "zh_Hans": "用于调用钉钉开放平台企业内部应用 API 的凭证。"
      },
      "icon": "🔑",
      "parameters": [
        {
          "name": "corp_id",
          "display_name": {
            "en_US": "Corp ID",
            "zh_Hans": "组织 ID"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "Organization ID where the DingTalk app is installed.",
              "zh_Hans": "钉钉应用所属组织的 Corp ID。"
            },
            "placeholder": {
              "en_US": "dingxxxxxxxxxxxx",
              "zh_Hans": "dingxxxxxxxxxxxx"
            },
            "width": "full",
            "component": "input"
          },
          "type": "string"
        },
        {
          "name": "client_id",
          "display_name": {
            "en_US": "Client ID",
            "zh_Hans": "应用 Client ID"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "Found in the DingTalk developer console under app credentials.",
              "zh_Hans": "可在钉钉开发者后台的应用凭证中找到。"
            },
            "placeholder": {
              "en_US": "dingoa...",
              "zh_Hans": "dingoa..."
            },
            "width": "full",
            "component": "input"
          },
          "type": "string"
        },
        {
          "name": "client_secret",
          "display_name": {
            "en_US": "Client Secret",
            "zh_Hans": "应用 Client Secret"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "Keep this secret secure. It is used to fetch access tokens at runtime.",
              "zh_Hans": "请妥善保管。运行时会用它来获取 access token。"
            },
            "placeholder": {
              "en_US": "App secret",
              "zh_Hans": "应用密钥"
            },
            "sensitive": true,
            "width": "full",
            "component": "encrypted-input"
          },
          "type": "encrypted_string"
        },
        {
          "name": "user_union_id",
          "display_name": {
            "en_US": "Default Operator unionId",
            "zh_Hans": "默认操作人 unionId"
          },
          "required": false,
          "ui": {
            "hint": {
              "en_US": "Optional default operator unionId for document and workflow operations. Tools can still override it.",
              "zh_Hans": "可选。用于文档和审批等操作的默认操作人 unionId；工具里仍可覆盖。"
            },
            "placeholder": {
              "en_US": "unionId",
              "zh_Hans": "unionId"
            },
            "width": "full",
            "component": "input"
          },
          "type": "string"
        }
      ]
    }
  ],
  "models": [],
  "tools": [
    {
      "name": "dingtalk-auth-get-access-token",
      "display_name": {
        "en_US": "Get App Access Token",
        "zh_Hans": "获取应用 Access Token"
      },
      "description": {
        "en_US": "Fetch the current DingTalk app access token using the selected credential.",
        "zh_Hans": "使用所选凭证获取当前钉钉应用的 access token。"
      },
      "icon": "🔐",
      "parameters": [
        {
          "name": "credential_id",
          "display_name": {
            "en_US": "Credential",
            "zh_Hans": "凭证"
          },
          "required": true,
          "ui": {
            "component": "credential-select"
          },
          "type": "credential_id",
          "credential_name": "dingtalk-app"
        }
      ]
    },
    {
      "name": "dingtalk-robot-batch-send",
      "display_name": {
        "en_US": "Batch Send Robot Message",
        "zh_Hans": "批量发送机器人消息"
      },
      "description": {
        "en_US": "Send one-to-one robot messages in batch.",
        "zh_Hans": "批量发送人与机器人单聊消息。"
      },
      "icon": "🤖",
      "parameters": [
        {
          "name": "credential_id",
          "display_name": {
            "en_US": "Credential",
            "zh_Hans": "凭证"
          },
          "required": true,
          "ui": {
            "component": "credential-select"
          },
          "type": "credential_id",
          "credential_name": "dingtalk-app"
        },
        {
          "name": "robot_code",
          "display_name": {
            "en_US": "Robot Code",
            "zh_Hans": "机器人编码"
          },
          "required": true,
          "ai": {
            "llm_description": {
              "en_US": "DingTalk robot code used to send the batch robot message.",
              "zh_Hans": "用于发送批量机器人消息的钉钉机器人编码。"
            }
          },
          "ui": {
            "support_expression": true,
            "width": "full",
            "component": "input"
          },
          "type": "string"
        },
        {
          "name": "user_ids",
          "display_name": {
            "en_US": "User IDs",
            "zh_Hans": "用户 ID 列表"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "Up to 20 userIds per request.",
              "zh_Hans": "每次请求最多 20 个 userId。"
            },
            "component": "tag-input"
          },
          "type": "array",
          "items": {
            "name": "user_ids_item",
            "type": "string"
          }
        },
        {
          "name": "message_type",
          "display_name": {
            "en_US": "Message Type",
            "zh_Hans": "消息类型"
          },
          "required": false,
          "ai": {
            "llm_description": {
              "en_US": "Robot message type. Supported values include text, link, markdown, actionCard, and feedCard.",
              "zh_Hans": "机器人消息类型。支持 text、link、markdown、actionCard 和 feedCard。"
            }
          },
          "ui": {
            "support_expression": true,
            "options": [
              {
                "label": {
                  "en_US": "Text",
                  "zh_Hans": "文本"
                },
                "value": "text"
              },
              {
                "label": {
                  "en_US": "Link",
                  "zh_Hans": "链接"
                },
                "value": "link"
              },
              {
                "label": {
                  "en_US": "Markdown",
                  "zh_Hans": "Markdown"
                },
                "value": "markdown"
              },
              {
                "label": {
                  "en_US": "Action Card",
                  "zh_Hans": "Action Card"
                },
                "value": "actionCard"
              },
              {
                "label": {
                  "en_US": "Feed Card",
                  "zh_Hans": "Feed Card"
                },
                "value": "feedCard"
              }
            ],
            "component": "select"
          },
          "type": "string",
          "default": "text",
          "enum": [
            "text",
            "link",
            "markdown",
            "actionCard",
            "feedCard"
          ]
        },
        {
          "name": "message_json",
          "display_name": {
            "en_US": "Message JSON",
            "zh_Hans": "消息 JSON"
          },
          "required": true,
          "ai": {
            "llm_description": {
              "en_US": "JSON object for the selected robot message type. For text use content; for markdown use title and text.",
              "zh_Hans": "与所选机器人消息类型匹配的 JSON 对象。文本消息使用 content；Markdown 消息使用 title 和 text。"
            }
          },
          "ui": {
            "hint": {
              "en_US": "Use a JSON object matching the selected message type. For text, provide a content field. For markdown, provide title and text fields.",
              "zh_Hans": "填写与所选消息类型匹配的 JSON 对象。文本消息需要 content 字段；Markdown 消息需要 title 和 text 字段。"
            },
            "support_expression": true,
            "width": "full",
            "component": "code-editor"
          },
          "type": "string"
        }
      ]
    },
