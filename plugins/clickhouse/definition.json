{
  "name": "clickhouse",
  "display_name": {
    "en_US": "ClickHouse",
    "zh_Hans": "ClickHouse"
  },
  "description": {
    "en_US": "Connect to ClickHouse database, run queries, insert data, export results, and check connectivity.",
    "zh_Hans": "连接 ClickHouse 数据库，执行查询、插入数据、导出结果并检查连通性。"
  },
  "icon": "🏠",
  "lang": "typescript",
  "repo": "https://github.com/choice-open/atomemo-official-plugins/plugins/clickhouse",
  "locales": [
    "en-US",
    "zh-Hans"
  ],
  "author": "yong yu",
  "email": "leoyyong@gmail.com",
  "version": "0.1.0",
  "credentials": [
    {
      "name": "clickhouse-connection",
      "display_name": {
        "en_US": "ClickHouse Connection",
        "zh_Hans": "ClickHouse 连接"
      },
      "description": {
        "en_US": "Connection settings for a ClickHouse instance.",
        "zh_Hans": "ClickHouse 实例的连接配置。"
      },
      "icon": "🏠",
      "parameters": [
        {
          "name": "url",
          "display_name": {
            "en_US": "ClickHouse URL",
            "zh_Hans": "ClickHouse 地址"
          },
          "required": true,
          "ui": {
            "placeholder": {
              "en_US": "http://localhost:8123",
              "zh_Hans": "http://localhost:8123"
            },
            "support_expression": false,
            "width": "full",
            "component": "input"
          },
          "type": "string"
        },
        {
          "name": "username",
          "display_name": {
            "en_US": "Username",
            "zh_Hans": "用户名"
          },
          "required": false,
          "ui": {
            "support_expression": false,
            "width": "full",
            "component": "input"
          },
          "type": "string",
          "default": "default"
        },
        {
          "name": "password",
          "display_name": {
            "en_US": "Password",
            "zh_Hans": "密码"
          },
          "required": false,
          "ui": {
            "sensitive": true,
            "support_expression": false,
            "width": "full",
            "component": "input"
          },
          "type": "string"
        },
        {
          "name": "database",
          "display_name": {
            "en_US": "Default Database",
            "zh_Hans": "默认数据库"
          },
          "required": false,
          "ui": {
            "support_expression": false,
            "width": "full",
            "component": "input"
          },
          "type": "string",
          "default": "default"
        }
      ]
    }
  ],
  "models": [],
  "tools": [
    {
      "name": "clickhouse-ping",
      "display_name": {
        "en_US": "ClickHouse Ping",
        "zh_Hans": "ClickHouse 连通性检查"
      },
      "description": {
        "en_US": "Check the health of a ClickHouse instance using the JS client.",
        "zh_Hans": "使用 clickhouse-js 检查 ClickHouse 实例的连通性和健康状态。"
      },
      "icon": "🩺",
      "parameters": [
        {
          "name": "connection",
          "display_name": {
            "en_US": "ClickHouse Connection",
            "zh_Hans": "ClickHouse 连接"
          },
          "required": true,
          "type": "credential_id",
          "credential_name": "clickhouse-connection"
        },
        {
          "name": "use_select_mode",
          "display_name": {
            "en_US": "Use SELECT ping (web-friendly)",
            "zh_Hans": "使用 SELECT 方式 ping（适合 Web 环境）"
          },
          "required": false,
          "ui": {
            "component": "switch"
          },
          "type": "boolean",
          "default": false
        }
      ]
    },
    {
      "name": "clickhouse-query-json",
      "display_name": {
        "en_US": "ClickHouse Query (JSON)",
        "zh_Hans": "ClickHouse 查询（JSON）"
      },
      "description": {
        "en_US": "Run a SELECT query against ClickHouse and return JSONEachRow data.",
        "zh_Hans": "对 ClickHouse 执行 SELECT 查询，并以 JSONEachRow 形式返回结果。"
      },
      "icon": "🔍",
      "parameters": [
        {
          "name": "connection",
          "display_name": {
            "en_US": "ClickHouse Connection",
            "zh_Hans": "ClickHouse 连接"
          },
          "required": true,
          "type": "credential_id",
          "credential_name": "clickhouse-connection"
        },
        {
          "name": "query",
          "display_name": {
            "en_US": "SQL Query",
            "zh_Hans": "SQL 查询语句"
          },
          "required": true,
          "ui": {
            "support_expression": true,
            "width": "full",
            "component": "textarea"
          },
          "type": "string"
        },
        {
          "name": "query_params",
          "display_name": {
            "en_US": "Query Parameters",
            "zh_Hans": "查询参数"
          },
          "required": false,
          "ui": {
            "support_expression": true,
            "width": "full",
            "component": "textarea"
          },
          "type": "string"
        },
        {
          "name": "clickhouse_settings",
          "display_name": {
            "en_US": "ClickHouse Settings",
            "zh_Hans": "ClickHouse 设置"
          },
          "required": false,
          "ui": {
            "support_expression": true,
            "width": "full",
            "component": "textarea"
          },
          "type": "string"
        },
        {
          "name": "max_rows",
          "display_name": {
            "en_US": "Max Rows",
            "zh_Hans": "最大行数"
          },
          "required": false,
          "ui": {
            "component": "number-input"
          },
          "type": "number",
          "default": 1000
        },
        {
          "name": "session_id",
          "display_name": {
            "en_US": "Session ID",
            "zh_Hans": "会话 ID"
          },
          "required": false,
          "ui": {
            "width": "full",
            "component": "input"
          },
          "type": "string"
        },
        {
          "name": "query_id",
          "display_name": {
            "en_US": "Query ID",
            "zh_Hans": "查询 ID"
          },
          "required": false,
          "ui": {
            "width": "full",
            "component": "input"
          },
          "type": "string"
        }
      ]
    },
    {
      "name": "clickhouse-query-export",
      "display_name": {
        "en_US": "ClickHouse Query Export (Streaming)",
        "zh_Hans": "ClickHouse 流式查询导出"
      },
      "description": {
        "en_US": "Stream large SELECT results to a file without loading into memory.",
        "zh_Hans": "将大查询结果流式写入文件，避免一次性加载到内存。"
      },
      "icon": "📤",
      "parameters": [
        {
          "name": "connection",
          "display_name": {
            "en_US": "ClickHouse Connection",
            "zh_Hans": "ClickHouse 连接"
          },
          "required": true,
          "type": "credential_id",
          "credential_name": "clickhouse-connection"
        },
        {
          "name": "query",
          "display_name": {
            "en_US": "SQL Query",
            "zh_Hans": "SQL 查询"
          },
          "required": true,
          "ui": {
            "support_expression": true,
            "width": "full",
            "component": "textarea"
          },
          "type": "string"
        },
        {
          "name": "output_path",
          "display_name": {
            "en_US": "Output File Path",
            "zh_Hans": "输出文件路径"
          },
          "required": true,
          "ui": {
            "support_expression": true,
            "width": "full",
            "component": "input"
          },
          "type": "string"
        },
