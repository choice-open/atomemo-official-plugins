{
  "name": "supabase-api-client",
  "type": "module",
  "version": "0.1.14",
  "description": "supabase api client",
  "author": "yong yu <leoyyong@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/choice-open/atomemo-official-plugins/plugins/supabase-api-client#readme",
  "repository": "https://github.com/choice-open/atomemo-official-plugins/plugins/supabase-api-client",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dist": "bun run ./dist/index.mjs",
    "check": "biome check . --write",
    "dev": "concurrently -c=cyan.bold,blue.bold --names=DEV,I18N --pad-prefix \"tsdown --watch\" \"typesafe-i18n\"",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "release": "bumpp package.json definition.json --commit 'release supabase-api-client v%s' --no-push --no-tag --yes",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@choiceopen/atomemo-plugin-sdk-js": "latest",
    "@supabase/supabase-js": "^2.101.1",
    "dotenv": "^17.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "@vitest/coverage-v8": "^4.1.2",
    "bumpp": "^10.4.1",
    "concurrently": "9.2.1",
    "tsdown": "^0.20.3",
    "typesafe-i18n": "^5.27.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "private": true
}
