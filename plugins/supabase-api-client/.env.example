# 用于本地调试与 e2e 测试，请勿提交真实密钥。
# 复制为 .env 并填写真实值：
#   cp .env.example .env

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key
# Service Role Key（可选）：Edge Function 等推荐使用，e2e 若配置则优先用此 key
SUPABASE_SERVICE_ROLE_KEY=
# Publishable key (anon) e2e 用，可选
SUPABASE_ANON_KEY=your-anon-publishable-key
# Auth e2e：已存在的测试账号邮箱与密码，未设置则跳过 auth.e2e.test
E2E_AUTH_EMAIL=
E2E_AUTH_PASSWORD=
# Edge Function e2e：已部署的函数名（如 hello）；且需 RUN_EDGE_FUNCTION_E2E=1 才会执行该 suite
EDGE_FUNCTION_NAME=
RUN_EDGE_FUNCTION_E2E=0