{
  "name": "airtable",
  "display_name": {
    "en_US": "Airtable",
    "zh_Hans": "Airtable"
  },
  "description": {
    "en_US": "Work with Airtable bases and records. List bases, retrieve schema, and create, read, search, update, upsert, and delete records.",
    "zh_Hans": "操作 Airtable 数据库和记录。列出数据库、获取表结构，以及创建、读取、搜索、更新、增改和删除记录。"
  },
  "icon": "symbol:icon-airtable",
  "lang": "typescript",
  "repo": "https://github.com/choice-open/atomemo-official-plugins/plugins/airtable",
  "locales": [
    "en-US",
    "zh-Hans"
  ],
  "author": "Xavier",
  "email": "zhiqiang.jiang@choiceform.com",
  "version": "0.0.1",
  "credentials": [
    {
      "name": "airtable",
      "display_name": {
        "en_US": "Airtable Personal Access Token",
        "zh_Hans": "Airtable 个人访问令牌"
      },
      "description": {
        "en_US": "Personal Access Token used to authenticate Airtable API requests.",
        "zh_Hans": "用于鉴权 Airtable API 请求的个人访问令牌。"
      },
      "icon": "🔑",
      "parameters": [
        {
          "name": "api_key",
          "display_name": {
            "en_US": "Personal Access Token",
            "zh_Hans": "个人访问令牌"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "Create your token at https://airtable.com/create/tokens. Ensure it has the required scopes for the operations you want to perform.",
              "zh_Hans": "在 https://airtable.com/create/tokens 创建令牌，并确保具有所需操作的权限范围。"
            },
            "placeholder": {
              "en_US": "patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX",
              "zh_Hans": "patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
            },
            "sensitive": true,
            "width": "full",
            "component": "encrypted-input"
          },
          "type": "encrypted_string"
        }
      ]
    }
  ],
  "models": [],
  "tools": [
    {
      "name": "airtable-list-bases",
      "display_name": {
        "en_US": "Get Many Bases",
        "zh_Hans": "获取多个数据库"
      },
      "description": {
        "en_US": "Return a list of all bases accessible to the authenticated user. Uses the List bases API: offset-based pagination when Return All is on; limit 1–100 when off. Optionally filter by permission level.",
        "zh_Hans": "返回当前认证用户可访问的所有数据库（List bases API）。勾选「返回全部」时使用 offset 分页；不勾选时限制 1–100 条。可按权限级别筛选。"
      },
      "icon": "🗂️",
      "parameters": [
        {
          "name": "airtable_credential",
          "display_name": {
            "en_US": "Airtable Credential",
            "zh_Hans": "Airtable 凭证"
          },
          "required": true,
          "ui": {
            "component": "credential-select"
          },
          "type": "credential_id",
          "credential_name": "airtable"
        },
        {
          "name": "return_all",
          "display_name": {
            "en_US": "Return All",
            "zh_Hans": "返回全部"
          },
          "required": false,
          "ui": {
            "component": "switch"
          },
          "type": "boolean",
          "default": true
        },
        {
          "name": "limit",
          "display_name": {
            "en_US": "Limit",
            "zh_Hans": "数量限制"
          },
          "required": false,
          "display": {
            "show": {
              "return_all": [
                false
              ]
            }
          },
          "ui": {
            "hint": {
              "en_US": "When Return All is off: max number of items to return (1–100). When Return All is on, the API uses offset-based pagination and all pages are fetched automatically.",
              "zh_Hans": "未勾选「返回全部」时：最多返回条数（1–100）。勾选「返回全部」时使用 offset 分页并自动请求所有页。"
            },
            "support_expression": true,
            "component": "number-input"
          },
          "type": "integer",
          "default": 100,
          "maximum": 100,
          "minimum": 1
        },
        {
          "name": "permission_level",
          "display_name": {
            "en_US": "Permission Level Filter",
            "zh_Hans": "权限级别筛选"
          },
          "required": false,
          "ui": {
            "hint": {
              "en_US": "Optional. Filter results by your permission on each base: None, Read only, Commenter, Creator, or Editor. Leave empty to return all bases regardless of permission level.",
              "zh_Hans": "可选。按你的权限筛选数据库：无、仅读、评论者、创建者或编辑者。留空则返回所有有权限的数据库。"
            },
            "options": [
              {
                "label": {
                  "en_US": "None",
                  "zh_Hans": "无"
                },
                "value": "none"
              },
              {
                "label": {
                  "en_US": "Read only",
                  "zh_Hans": "仅读"
                },
                "value": "read"
              },
              {
                "label": {
                  "en_US": "Commenter",
                  "zh_Hans": "评论者"
                },
                "value": "comment"
              },
              {
                "label": {
                  "en_US": "Creator",
                  "zh_Hans": "创建者"
                },
                "value": "create"
              },
              {
                "label": {
                  "en_US": "Editor",
                  "zh_Hans": "编辑者"
                },
                "value": "edit"
              }
            ],
            "component": "multi-select"
          },
          "type": "array",
          "items": {
            "name": "permission",
            "type": "string",
            "enum": [
              "none",
              "read",
              "comment",
              "create",
              "edit"
            ]
          }
        }
      ]
    },
    {
      "name": "airtable-get-base-schema",
      "display_name": {
        "en_US": "Get Base Schema",
        "zh_Hans": "获取 base 结构"
      },
      "description": {
        "en_US": "Retrieve the schema for a specific base. Response includes all tables (id, name, primaryFieldId) and their fields (id, name, type, description, options). Base ID is required (e.g. appXXXXXXXXXXXXXX); find it in the base URL or Help → API documentation.",
        "zh_Hans": "获取指定 base 的结构。返回所有表（id、name、primaryFieldId）及其字段（id、name、type、description、options）。Base ID 必填（如 appXXXXXXXXXXXXXX），可在 base 链接或帮助 → API 文档中查看。"
      },
      "icon": "📋",
      "parameters": [
        {
          "name": "airtable_credential",
          "display_name": {
            "en_US": "Airtable Credential",
            "zh_Hans": "Airtable 凭证"
          },
          "required": true,
          "ui": {
            "component": "credential-select"
          },
          "type": "credential_id",
          "credential_name": "airtable"
        },
        {
          "name": "base_id",
          "display_name": {
            "en_US": "Base ID",
            "zh_Hans": "数据库 ID"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "Required. Base ID from the base URL, Help → API documentation, or Get Many Bases. Format: app followed by 14 alphanumeric characters (e.g. appXXXXXXXXXXXXXX).",
              "zh_Hans": "必填。Base ID 来自 base 链接、帮助 → API 文档或「获取多个数据库」。格式：app 加 14 位字母数字（如 appXXXXXXXXXXXXXX）。"
            },
            "placeholder": {
              "en_US": "appXXXXXXXXXXXXXX",
              "zh_Hans": "appXXXXXXXXXXXXXX"
            },
            "support_expression": true,
            "width": "full",
            "component": "input"
          },
          "type": "string"
        }
      ]
    },
    {
      "name": "airtable-create-record",
      "display_name": {
        "en_US": "Create A Record",
        "zh_Hans": "创建一条记录"
      },
      "description": {
        "en_US": "Create a new record in an Airtable table.",
        "zh_Hans": "在 Airtable 表中创建新记录。"
      },
      "icon": "➕",
      "parameters": [
        {
          "name": "airtable_credential",
          "display_name": {
            "en_US": "Airtable Credential",
            "zh_Hans": "Airtable 凭证"
          },
          "required": true,
          "ui": {
            "component": "credential-select"
          },
          "type": "credential_id",
          "credential_name": "airtable"
        },
        {
          "name": "base_id",
          "display_name": {
            "en_US": "Base ID",
            "zh_Hans": "数据库 ID"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "Required. Base ID from the base URL, Help → API documentation, or Get Many Bases. Format: app followed by 14 alphanumeric characters (e.g. appXXXXXXXXXXXXXX).",
              "zh_Hans": "必填。Base ID 来自 base 链接、帮助 → API 文档或「获取多个数据库」。格式：app 加 14 位字母数字（如 appXXXXXXXXXXXXXX）。"
            },
            "placeholder": {
              "en_US": "appXXXXXXXXXXXXXX",
              "zh_Hans": "appXXXXXXXXXXXXXX"
            },
            "support_expression": true,
            "width": "full",
            "component": "input"
          },
          "type": "string"
        },
        {
          "name": "table",
          "display_name": {
            "en_US": "Table",
            "zh_Hans": "表"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "Required. Table name or table ID. Use the name as shown in the base, or the table ID (e.g. tblXXXXXXXXXXXXXX) from Get Base Schema.",
              "zh_Hans": "表名称或表 ID。可使用 base 中显示的表名，或从 base 结构中获取的 ID（如 tblXXXXXXXXXXXXXX）。"
            },
            "placeholder": {
              "en_US": "tblXXXXXXXXXXXXXX or Table Name",
              "zh_Hans": "tblXXXXXXXXXXXXXX 或表名称"
            },
            "support_expression": true,
            "width": "full",
            "component": "input"
          },
          "type": "string"
        },
        {
          "name": "fields",
          "display_name": {
            "en_US": "Fields",
            "zh_Hans": "字段"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "Required. JSON object: keys = field names (use names, not field IDs). Values: text, number, single select (string), checkbox (boolean), date (ISO 8601). Linked records: array of record IDs, e.g. \"Project\": [\"recXXX\"]. Collaborator: user ID or email per Airtable docs. With Typecast on, strings are converted to field types and linked records can use primary field value.",
              "zh_Hans": "必填。JSON 对象：键为字段名称（用名称勿用 ID）。值类型：文本、数字、单选、复选框、日期（ISO 8601）；链接记录为记录 ID 数组；协作者为 Airtable 文档中的用户 ID 或邮箱。开启 Typecast 时字符串会按字段类型转换，链接可按主字段值填写。"
            },
            "placeholder": {
              "en_US": "Example: {\"Name\": \"John\", \"Status\": \"Active\", \"Score\": 5, \"Project\": [\"recXXX\"]}",
              "zh_Hans": "示例：{\"Name\": \"John\", \"Status\": \"Active\", \"Score\": 5, \"Project\": [\"recXXX\"]}"
            },
            "support_expression": true,
            "width": "full",
            "component": "code-editor",
            "language": "json",
            "rows": 8
          },
          "type": "string"
        },
        {
          "name": "typecast",
          "display_name": {
            "en_US": "Typecast",
            "zh_Hans": "自动类型转换"
          },
          "required": false,
          "ui": {
            "hint": {
              "en_US": "When enabled, Airtable converts string values to the field type (e.g. \"5\" → number, \"true\" → checkbox) and can resolve linked records by primary field value instead of record ID. Disable when sending already-typed values to avoid unintended conversion.",
              "zh_Hans": "启用后，Airtable 会将字符串转为对应类型（例如 '5' 转为数字、'true' 转为复选框），链接记录可用主字段值解析。若已传入正确类型可关闭以避免意外转换。"
            },
            "support_expression": true,
            "component": "switch"
          },
          "type": "boolean",
          "default": false
        }
      ]
    },
    {
      "name": "airtable-get-record",
      "display_name": {
        "en_US": "Get A Record",
        "zh_Hans": "获取一条记录"
      },
      "description": {
        "en_US": "Retrieve a single record from an Airtable table by base_id, table (name or id), and record_id. Required: base_id, table, record_id.",
        "zh_Hans": "通过 base_id、表（名称或 id）和 record_id 获取单条记录。必填：base_id、table、record_id。"
      },
      "icon": "🔍",
      "parameters": [
        {
          "name": "airtable_credential",
          "display_name": {
            "en_US": "Airtable Credential",
            "zh_Hans": "Airtable 凭证"
          },
          "required": true,
          "ui": {
            "component": "credential-select"
          },
          "type": "credential_id",
          "credential_name": "airtable"
        },
        {
          "name": "base_id",
          "display_name": {
            "en_US": "Base ID",
            "zh_Hans": "数据库 ID"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "Required. Base ID from the base URL, Help → API documentation, or Get Many Bases. Format: app followed by 14 alphanumeric characters (e.g. appXXXXXXXXXXXXXX).",
              "zh_Hans": "必填。Base ID 来自 base 链接、帮助 → API 文档或「获取多个数据库」。格式：app 加 14 位字母数字（如 appXXXXXXXXXXXXXX）。"
            },
            "placeholder": {
              "en_US": "appXXXXXXXXXXXXXX",
              "zh_Hans": "appXXXXXXXXXXXXXX"
            },
            "support_expression": true,
            "width": "full",
            "component": "input"
          },
          "type": "string"
        },
        {
          "name": "table",
          "display_name": {
            "en_US": "Table",
            "zh_Hans": "表"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "Required. Table name or table ID. Use the name as shown in the base, or the table ID (e.g. tblXXXXXXXXXXXXXX) from Get Base Schema.",
              "zh_Hans": "表名称或表 ID。可使用 base 中显示的表名，或从 base 结构中获取的 ID（如 tblXXXXXXXXXXXXXX）。"
            },
            "placeholder": {
              "en_US": "tblXXXXXXXXXXXXXX or Table Name",
              "zh_Hans": "tblXXXXXXXXXXXXXX 或表名称"
            },
            "support_expression": true,
            "width": "full",
            "component": "input"
          },
          "type": "string"
        },
        {
          "name": "record_id",
          "display_name": {
            "en_US": "Record ID",
            "zh_Hans": "记录 ID"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "Required. Record ID format: rec + 14 alphanumeric characters (e.g. recXXXXXXXXXXXXXX). Find it in List/Search results as id, in the record URL, or right‑click record → Copy record link.",
              "zh_Hans": "必填。记录 ID 格式：rec 加 14 位字母数字（如 recXXXXXXXXXXXXXX）。可从列表/搜索结果的 id、记录链接或右键记录 → 复制记录链接获取。"
            },
            "placeholder": {
              "en_US": "recXXXXXXXXXXXXXX",
              "zh_Hans": "recXXXXXXXXXXXXXX"
            },
            "support_expression": true,
            "width": "full",
            "component": "input"
          },
          "type": "string"
        }
      ]
    },
    {
      "name": "airtable-search-records",
      "display_name": {
        "en_US": "Search Records",
        "zh_Hans": "搜索记录"
      },
      "description": {
        "en_US": "List and filter records (List records API). Supports filterByFormula, view, fields[], sort, and pagination (pageSize up to 100, maxRecords when Limit is set).",
        "zh_Hans": "列出并筛选记录（List records API）。支持 filterByFormula、view、fields[]、sort；分页为 pageSize 最多 100，设置数量限制时使用 maxRecords。"
      },
      "icon": "🔎",
      "parameters": [
        {
          "name": "airtable_credential",
          "display_name": {
            "en_US": "Airtable Credential",
            "zh_Hans": "Airtable 凭证"
          },
          "required": true,
          "ui": {
            "component": "credential-select"
          },
          "type": "credential_id",
          "credential_name": "airtable"
        },
        {
          "name": "base_id",
          "display_name": {
            "en_US": "Base ID",
            "zh_Hans": "数据库 ID"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "Required. Base ID from the base URL, Help → API documentation, or Get Many Bases. Format: app followed by 14 alphanumeric characters (e.g. appXXXXXXXXXXXXXX).",
              "zh_Hans": "必填。Base ID 来自 base 链接、帮助 → API 文档或「获取多个数据库」。格式：app 加 14 位字母数字（如 appXXXXXXXXXXXXXX）。"
            },
            "placeholder": {
              "en_US": "appXXXXXXXXXXXXXX",
              "zh_Hans": "appXXXXXXXXXXXXXX"
            },
            "support_expression": true,
            "width": "full",
            "component": "input"
          },
          "type": "string"
        },
        {
          "name": "table",
          "display_name": {
            "en_US": "Table",
            "zh_Hans": "表"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "Required. Table name or table ID. Use the name as shown in the base, or the table ID (e.g. tblXXXXXXXXXXXXXX) from Get Base Schema.",
              "zh_Hans": "表名称或表 ID。可使用 base 中显示的表名，或从 base 结构中获取的 ID（如 tblXXXXXXXXXXXXXX）。"
            },
            "placeholder": {
              "en_US": "tblXXXXXXXXXXXXXX or Table Name",
              "zh_Hans": "tblXXXXXXXXXXXXXX 或表名称"
            },
            "support_expression": true,
            "width": "full",
            "component": "input"
          },
          "type": "string"
        },
        {
          "name": "filter_by_formula",
          "display_name": {
            "en_US": "Filter By Formula",
            "zh_Hans": "过滤公式"
          },
          "required": false,
          "ui": {
            "hint": {
              "en_US": "Optional. Airtable filterByFormula; only records where the formula result is non-zero, non-empty, and not #Error! are returned. Use field names in curly braces. With View, results are limited to that view then filtered. Request URL length limit (~16k characters) applies. See https://airtable.com/developers/web/api/list-records#query-filterbyformula",
              "zh_Hans": "可选。Airtable filterByFormula；仅当公式结果非 0、非空且不为 #Error! 时返回记录。字段名用花括号。与视图同用时先限制视图再按公式筛选。注意请求 URL 长度限制（约 16k 字符）。详见 https://airtable.com/developers/web/api/list-records#query-filterbyformula"
            },
            "placeholder": {
              "en_US": "",
              "zh_Hans": ""
            },
            "support_expression": true,
            "width": "full",
            "component": "textarea"
          },
          "type": "string"
        },
        {
          "name": "return_all",
          "display_name": {
            "en_US": "Return All",
            "zh_Hans": "返回全部"
          },
          "required": false,
          "ui": {
            "component": "switch"
          },
          "type": "boolean",
          "default": true
        },
        {
          "name": "limit",
          "display_name": {
            "en_US": "Limit",
            "zh_Hans": "数量限制"
          },
          "required": false,
          "display": {
            "show": {
              "return_all": [
                false
              ]
            }
          },
          "ui": {
            "hint": {
              "en_US": "When Return All is off: max number of items to return (1–100). When Return All is on, the API uses offset-based pagination and all pages are fetched automatically.",
              "zh_Hans": "未勾选「返回全部」时：最多返回条数（1–100）。勾选「返回全部」时使用 offset 分页并自动请求所有页。"
            },
            "support_expression": true,
            "component": "number-input"
          },
          "type": "integer",
          "default": 100,
          "maximum": 100,
          "minimum": 1
        },
        {
          "name": "view",
          "display_name": {
            "en_US": "View",
            "zh_Hans": "视图"
          },
          "required": false,
          "ui": {
            "hint": {
              "en_US": "Optional. View name or ID. Restricts results to records in that view. If Sort is set, it overrides the view sort order. Leave empty for table default.",
              "zh_Hans": "可选。视图名称或 ID，将结果限制在该视图内。若设置排序会覆盖视图排序。留空使用表默认。"
            },
            "support_expression": true,
            "width": "full",
            "component": "input"
          },
          "type": "string"
        },
        {
          "name": "output_fields",
          "display_name": {
            "en_US": "Output Fields",
            "zh_Hans": "输出字段"
          },
          "required": false,
          "ui": {
            "hint": {
              "en_US": "Optional. Field names or IDs to return (fields[]); reduces payload. Leave empty to return all fields.",
              "zh_Hans": "可选。要返回的字段名称或 ID（fields[]），可减少返回数据。留空则返回全部字段。"
            },
            "component": "tag-input"
          },
          "type": "array",
          "items": {
            "name": "field_name",
            "type": "string"
          }
        },
        {
          "name": "sort",
          "display_name": {
            "en_US": "Sort",
            "zh_Hans": "排序"
          },
          "required": false,
          "ui": {
            "component": "array-section"
          },
          "type": "array",
          "items": {
            "name": "sort_rule",
            "type": "object",
            "properties": [
              {
                "name": "field",
                "display_name": {
                  "en_US": "Field",
                  "zh_Hans": "字段"
                },
                "required": true,
                "ui": {
                  "hint": {
                    "en_US": "Field name or ID for sort (sort[0][field], sort[0][direction]). Add multiple rules for secondary sort (asc/desc).",
                    "zh_Hans": "排序字段名称或 ID（sort[0][field]、sort[0][direction]）。可添加多条规则实现多级排序（升序/降序）。"
                  },
                  "support_expression": true,
                  "component": "input"
                },
                "type": "string"
              },
              {
                "name": "direction",
                "display_name": {
                  "en_US": "Direction",
                  "zh_Hans": "方向"
                },
                "required": false,
                "ui": {
