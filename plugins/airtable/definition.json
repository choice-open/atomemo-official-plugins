{
  "name": "airtable",
  "display_name": {
    "en_US": "Airtable",
    "zh_Hans": "Airtable"
  },
  "description": {
    "en_US": "Work with Airtable bases and records. List bases, retrieve schema, and create, read, search, update, upsert, and delete records.",
    "zh_Hans": "操作 Airtable 数据库和记录。列出数据库、获取表结构，以及创建、读取、搜索、更新、增改和删除记录。"
  },
  "icon": "symbol:icon-airtable",
  "lang": "typescript",
  "repo": "https://github.com/choice-open/atomemo-official-plugins/plugins/airtable",
  "locales": [
    "en-US",
    "zh-Hans"
  ],
  "author": "Xavier",
  "email": "zhqjiang@outlook.com",
  "version": "0.4.0",
  "credentials": [
    {
      "name": "airtable",
      "display_name": {
        "en_US": "Airtable Personal Access Token",
        "zh_Hans": "Airtable 个人访问令牌"
      },
      "description": {
        "en_US": "Personal Access Token used to authenticate Airtable API requests.",
        "zh_Hans": "用于鉴权 Airtable API 请求的个人访问令牌。"
      },
      "icon": "🔑",
      "parameters": [
        {
          "name": "api_key",
          "display_name": {
            "en_US": "Personal Access Token",
            "zh_Hans": "个人访问令牌"
          },
          "required": true,
          "ui": {
            "hint": {
              "en_US": "Create your token at https://airtable.com/create/tokens. Ensure it has the required scopes for the operations you want to perform.",
              "zh_Hans": "在 https://airtable.com/create/tokens 创建令牌，并确保具有所需操作的权限范围。"
            },
            "placeholder": {
              "en_US": "patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX",
              "zh_Hans": "patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
            },
            "sensitive": true,
            "width": "full",
            "component": "encrypted-input"
          },
          "type": "encrypted_string"
        }
      ]
    }
  ],
  "models": [],
  "tools": [
    {
      "name": "airtable-create-record",
      "display_name": {
        "en_US": "Create A Record",
        "zh_Hans": "创建一条记录"
      },
      "description": {
        "en_US": "Create a new record in an Airtable table.",
        "zh_Hans": "在 Airtable 表中创建新记录。"
      },
      "icon": "➕",
      "parameters": [
        {
          "name": "airtable_credential",
          "display_name": {
            "en_US": "Airtable Credential",
            "zh_Hans": "Airtable 凭证"
          },
          "required": true,
          "ui": {
            "component": "credential-select"
          },
          "type": "credential_id",
          "credential_name": "airtable"
        },
        {
          "name": "base_id",
          "display_name": {
            "en_US": "Base ID",
            "zh_Hans": "数据库 ID"
          },
          "required": true,
          "ai": {
            "llm_description": {
              "en_US": "Required. Base ID from the base URL, Help → API documentation, or Get Many Bases. Format: app followed by 14 alphanumeric characters (e.g. appXXXXXXXXXXXXXX).",
              "zh_Hans": "必填。Base ID 来自 base 链接、帮助 → API 文档或「获取多个数据库」。格式：app 加 14 位字母数字（如 appXXXXXXXXXXXXXX）。"
            }
          },
          "type": "resource_locator",
          "modes": [
            {
              "type": "list",
              "display_name": {
                "en_US": "Choose from accessible bases",
                "zh_Hans": "从可访问的数据库中选择"
              },
              "search_list_method": "search_bases",
              "searchable": true
            },
            {
              "type": "id",
              "display_name": {
                "en_US": "Enter base ID",
                "zh_Hans": "输入数据库 ID"
              }
            }
          ]
        }
      ]
    }
  ]
}